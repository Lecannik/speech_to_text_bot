# Токен Telegram бота (получается у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Настройки Whisper модели
# Доступные размеры: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=medium

# Устройство для вычислений: cpu или cuda (если доступен GPU)
WHISPER_DEVICE=cpu

# Тип вычислений. Для CPU рекомендуется int8 (быстрее и экономит RAM) или float32
WHISPER_COMPUTE_TYPE=int8

# Ключ API для генерации Summary (второе сообщение)
# В зависимости от используемой LLM (например, OpenAI API или Gemini API)
# API_PROVIDER=openai # или gemini
# OPENAI_API_KEY=your_openai_key
# GEMINI_API_KEY=your_gemini_key
