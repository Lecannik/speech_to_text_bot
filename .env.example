# Токен основного Telegram бота (рабочий бот, получается у @BotFather)
BOT_TOKEN=your_main_bot_token

# Настройки Whisper модели (STT)
# Доступные размеры: tiny, base, small, medium, large-v3
# Для качественного русского языка рекомендуется: medium. 
# Для слабых машин (до 8 ГБ RAM) используйте: small.
WHISPER_MODEL_SIZE=medium

# Устройство для вычислений: cpu или cuda (если доступен GPU)
WHISPER_DEVICE=cpu

# Тип вычислений. Для CPU рекомендуется int8 (быстрее и экономит RAM) или float32
WHISPER_COMPUTE_TYPE=int8

# Настройки локальной LLM модели (Ollama / Summary)
# Для Docker-окружения: http://ollama:11434
# Для локального тестирования на ПК: http://localhost:11434
OLLAMA_HOST=http://ollama:11434

# Название модели в Ollama. Рекомендуется: qwen2.5:3b (отличный русский язык) 
# Для экономии памяти (до 8 ГБ RAM) используйте: qwen2.5:1.5b
OLLAMA_MODEL=qwen2.5:3b

# Кастомный промпт для генерации выжимки
# SUMMARY_PROMPT=Сделай краткую выжимку следующего текста...
